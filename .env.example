# ─── Tavera — Environment Variables Template ──────────────────────────────────
#
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
#
# The .env file is loaded at runtime during local development.
# For production builds, pass all keys via --dart-define flags instead
# (see README.md → Building for Release).
#
# NEVER commit your .env file — it is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# The anon key is safe to include here — it is protected by Row-Level Security.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Gemini (AI food recognition + coaching) ────────────────────────────
# Used by Supabase Edge Functions — set this as a Supabase secret, not here.
# Dashboard → Edge Functions → Secrets → Add → GEMINI_API_KEY
# Get a free key at: https://aistudio.google.com
# Free tier: 1,500 requests/day (gemini-2.0-flash-002)
GEMINI_API_KEY=AIzaSy...

# ── RevenueCat (in-app subscriptions) ────────────────────────────────────────
# Use the PUBLIC SDK key for the Flutter app (appl_... / goog_... / test_...).
# Do NOT use the V2 secret key (sk_...) here — that is for server-to-server only.
# Found in: RevenueCat Dashboard → Project Settings → API Keys → Public app-specific keys
REVENUECAT_API_KEY_IOS=appl_...
REVENUECAT_API_KEY_ANDROID=goog_...

# ── PostHog (product analytics) ───────────────────────────────────────────────
# Leave empty to disable analytics in development.
# Found in: PostHog Dashboard → Project Settings → Project API Key
POSTHOG_API_KEY=phc_...
